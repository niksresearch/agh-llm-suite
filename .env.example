# AGH LLM Suite — Environment Variables
# bootstrap.sh auto-generates secrets if left empty.

# Bundle: 1=single-key API, 2=multi-key API, 3=multi-key + Virtual Desktop + UduChat
BUNDLE=2

# Model (set by bundles/bundleN.env — override only if needed)
MODEL=gemma-4-31B-it-GGUF
OLLAMA_NUM_CTX=65536
RATE_LIMIT_RPM=60

# Secrets — leave empty to auto-generate at deploy time
LLM_API_KEY=
ADMIN_TOKEN=        # Bundle 2+ only

# Optional: named cloudflare tunnel token (leave empty for ephemeral trycloudflare.com URL)
TUNNEL_TOKEN=

# Optional: POST deploy result (success + failure) to this URL
WEBHOOK_URL=

# Bundle 3 only: Virtual Desktop VNC password
VD_PASS=changeme
